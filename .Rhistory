library(rmarkdown)
library(knitr)
library(markdown)
library(tidyverse)
library(edgeR)
library(SummarizedExperiment)
library(patchwork)
library(DT)
library(limma)
library(plotly)
library(RColorBrewer)
library(ggrepel)
knitr::opts_chunk$set(echo=FALSE, warning=FALSE, message=FALSE)
dir.create("2.Pre-processing_of_raw_reads", showWarnings = FALSE)
suppressMessages(
file.copy("multiqc_report.html",
"2.Pre-processing_of_raw_reads/multiqc_report.html",
overwrite = TRUE)
)
# Load sample metadata
sampleinfo <- read.delim("metadata.txt", header = TRUE)
sampleinfo$sample <- as.character(sampleinfo$sample)
# Load raw gene count data from Salmon
se <- readRDS("salmon.merged.gene.SummarizedExperiment.rds")
counts <- assay(se, "salmon.merged.gene_counts")
# Clean up column names
colnames(counts) <- gsub("^X\\.", "", colnames(counts))
colnames(counts) <- gsub("\\.", "-", colnames(counts))
# Align count matrix column order to metadata
counts.matrix <- data.matrix(counts[, match(sampleinfo$sample, colnames(counts))])
# Load gene annotations (GRCh38 / Gencode v38)
geneinfo <- read.delim(
'/Users/zhongyu/Work/bioinfo_analysis/CRI_BIO_1176_Human/ref_Annotation/gencode.v38.primary_assembly.annotation.gtf.geneinfo'
)
# Reorder annotations to match count matrix row order
geneinfo <- geneinfo[match(rownames(counts.matrix), geneinfo$gene_id), ]
# Build DGEList
myDGEList <- edgeR::DGEList(
counts  = counts.matrix,
samples = sampleinfo,
genes   = geneinfo
)
# Save raw gene counts with annotation
readr::write_csv(
as_tibble(myDGEList$counts, rownames = 'geneID') %>%
tibble::add_column(geneName = geneinfo$gene_name) %>%
dplyr::select(geneID, geneName, everything()),
"2.Pre-processing_of_raw_reads/raw_gene_counts.csv"
)
# Remove duplicated gene names
gene_lookup <- tibble::as_tibble_col(rownames(myDGEList), column_name = 'gene_id') %>%
dplyr::left_join(geneinfo)
myDGEList <- myDGEList[!duplicated(gene_lookup$gene_name), ]
rownames(myDGEList) <- gene_lookup$gene_name[!duplicated(gene_lookup$gene_name)]
# Save deduplicated raw counts
readr::write_csv(
as_tibble(myDGEList$counts, rownames = 'gene_name'),
"2.Pre-processing_of_raw_reads/gene_counts.csv"
)
dir.create("3.Quality_control", showWarnings = FALSE)
# Filter low-expression genes: CPM > 1 in at least 2 samples
keepers.expr <- rowSums(cpm(myDGEList) > 1) >= 2
myDGEList.filtered <- myDGEList[keepers.expr, , keep.lib.sizes = FALSE]
# Retain protein-coding genes only
protein_coding_genes <- geneinfo %>%
as_tibble() %>%
dplyr::filter(gene_type == 'protein_coding') %>%
pull(gene_name) %>%
unique()
keepers.pc <- rownames(myDGEList.filtered) %in% protein_coding_genes
myDGEList.protein_coding <- myDGEList.filtered[keepers.pc, ]
# TMM normalization
myDGEList.norm <- edgeR::calcNormFactors(myDGEList.protein_coding, method = "TMM")
# Save normalized counts (raw counts with TMM norm factors applied, for reference)
readr::write_csv(
as_tibble(myDGEList.norm$counts, rownames = 'gene_name'),
"3.Quality_control/counts_norm.csv"
)
# Save normalized CPM
cpm.norm <- edgeR::cpm(myDGEList.norm, log = FALSE) %>%
as_tibble(rownames = "gene_name")
readr::write_csv(cpm.norm, "3.Quality_control/cpm_norm.csv")
# Save log2 normalized CPM
log2.cpm.norm <- edgeR::cpm(myDGEList.norm, log = TRUE) %>%
as_tibble(rownames = "gene_name")
readr::write_csv(log2.cpm.norm, "3.Quality_control/log2_cpm_norm.csv")
L <- mean(myDGEList$samples$lib.size) * 1e-6
M <- median(myDGEList$samples$lib.size) * 1e-6
log2.cpm.cutoff <- log2(10 / M + 2 / L)
plot_gene_expression <- function(mydeglist, subtitle) {
log2.cpm <- edgeR::cpm(mydeglist, log = TRUE) %>%
as_tibble(rownames = "gene_name")
log2.cpm.pivot <- tidyr::pivot_longer(
log2.cpm,
cols = -1,
names_to = "samples",
values_to = "expression"
)
p1 <- ggplot(log2.cpm.pivot, aes(x = expression, group = samples, color = samples)) +
geom_density(show.legend = FALSE) +
labs(y = "Density", x = "log2 CPM") +
theme_bw() +
geom_vline(xintercept = log2.cpm.cutoff, color = "gray", linetype = "dashed")
p2 <- ggplot(log2.cpm.pivot) +
aes(x = samples, y = expression, fill = samples) +
geom_violin(trim = FALSE, show.legend = FALSE) +
geom_hline(yintercept = log2.cpm.cutoff, color = "gray", linetype = "dashed") +
stat_summary(fun = "median", geom = "point", shape = 95, size = 10,
color = "black", show.legend = FALSE) +
labs(y = "log2 CPM", x = "Sample") +
theme_bw() +
theme(axis.text.x = element_text(angle = 45, vjust = 0.5))
p1 + p2 +
plot_layout(widths = c(1, 2)) +
plot_annotation(
title    = "Log2 Counts per Million (CPM)",
subtitle = subtitle,
caption  = paste0("produced on ", Sys.time())
) &
theme(plot.title = element_text(hjust = 0.5))
}
plot_gene_expression(myDGEList, "Unfiltered, non-normalized")
plot_gene_expression(myDGEList.protein_coding, "Filtered, non-normalized")
plot_gene_expression(myDGEList.norm, "Filtered, TMM-normalized")
log2.cpm.df <- edgeR::cpm(myDGEList.norm, log = TRUE) %>%
as_tibble(rownames = "gene_name") %>%
dplyr::mutate_if(is.numeric, round, 3)
DT::datatable(
log2.cpm.df,
rownames    = FALSE,
extensions  = c('KeyTable', 'FixedHeader'),
filter      = 'top',
caption     = 'TMM-normalized log2 CPM — all samples',
options     = list(
keys            = TRUE,
searchHighlight = TRUE,
pageLength      = 20,
lengthMenu      = c("10", "25", "50", "100")
)
)
dir.create("4.Exploratory_data_analysis", showWarnings = FALSE)
# Use normalized log2 CPM matrix
log2.cpm.mat <- edgeR::cpm(myDGEList.norm, log = TRUE)
# Define per-sample color palette
sample_colors <- setNames(
RColorBrewer::brewer.pal(n = ncol(log2.cpm.mat), name = "Set2"),
colnames(log2.cpm.mat)
)
# Run PCA
pca.res <- prcomp(t(log2.cpm.mat), scale. = FALSE, retx = TRUE)
pc.var  <- pca.res$sdev^2
pc.per  <- round(pc.var / sum(pc.var) * 100, 1)
pca.df <- as_tibble(pca.res$x) %>%
dplyr::mutate(sample = rownames(pca.res$x)) %>%
dplyr::left_join(sampleinfo, by = "sample")
# --- PCA scatter plot with sample labels ---
p_pca <- ggplot(pca.df) +
aes(
x     = PC1,
y     = PC2,
color = sample,
text  = paste0(
"Sample: ", sample,
"<br>PC1: ", round(PC1, 2),
"<br>PC2: ", round(PC2, 2)
)
) +
geom_point(size = 4) +
ggrepel::geom_text_repel(
aes(label = sample),
size          = 3.5,
show.legend   = FALSE,
box.padding   = 0.4,
point.padding = 0.3,
max.overlaps  = Inf
) +
scale_color_manual(values = sample_colors) +
xlab(paste0("PC1 (", pc.per[1], "%)")) +
ylab(paste0("PC2 (", pc.per[2], "%)")) +
ggtitle("PCA — CRI-BIO-1201 Colon Organoids") +
coord_fixed() +
theme_bw() +
theme(legend.title = element_blank())
ggplotly(p_pca, tooltip = "text")
# --- Scree plot ---
scree.df <- tibble(
PC      = paste0("PC", seq_along(pc.per)),
Variance = pc.per
) %>%
dplyr::mutate(PC = factor(PC, levels = PC))
ggplot(scree.df[1:min(10, nrow(scree.df)), ], aes(x = PC, y = Variance)) +
geom_col(fill = "steelblue") +
geom_text(aes(label = paste0(Variance, "%")), vjust = -0.4, size = 3.5) +
labs(
title = "Scree Plot — Top 10 PCs",
x     = "Principal Component",
y     = "% Variance Explained"
) +
theme_bw()
# Save PCA coordinates
readr::write_csv(
pca.df %>% dplyr::select(sample, PC1, PC2, PC3, PC4, PC5),
"4.Exploratory_data_analysis/pca_coordinates.csv"
)
